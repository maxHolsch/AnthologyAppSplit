{
  "name": "anthology-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx scripts/api-server.ts",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "api:validate": "npx @apidevtools/swagger-cli validate docs/api/openapi.yaml",
