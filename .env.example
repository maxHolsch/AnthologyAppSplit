### Frontend (safe to expose)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

### Storage
# Bucket names are case-sensitive.
VITE_SUPABASE_RECORDINGS_BUCKET=Recordings
VITE_SUPABASE_CONVERSATIONS_BUCKET=Conversations

### API keys (server-side only)
# Used by local Vite dev middleware and Vercel serverless functions.
ASSEMBLYAI_API_KEY=YOUR-ASSEMBLYAI-KEY
OPENAI_API_KEY=YOUR-OPENAI-KEY

### Optional
# Overrides the default model used for sensemaking LLM calls.
OPENAI_SENSEMAKING_MODEL=gpt-5-mini-2025-08-07

### Server-side API (never expose to frontend)
# Used by API routes (Vercel serverless functions)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

### Legacy (still works for compatibility)
SUPABASE_SERVICE_KEY=YOUR-SERVICE-ROLE-KEY
